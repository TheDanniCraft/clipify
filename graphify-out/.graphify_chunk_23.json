    {
      "id": "compound_component_pattern",
      "label": "Compound Component Pattern",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/range-calendar.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "v3 uses a compound component pattern (e.g. Select.Trigger, Select.Value) instead of passing configuration via props. This provides developers with explicit layout control, custom styling flexibility, and clean composition without complex prop APIs."
    },
    {
      "id": "full_migration_workflow",
      "label": "Full Migration Workflow",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(workflows)/full-migration.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "v2 and v3 cannot coexist in the same project due to theme and stylesheet differences in full migration. Thus, a full migration branch is required to update all components before swapping the package dependencies to keep the transition clean."
    },
    {
      "id": "incremental_coexistence_migration",
      "label": "Incremental Coexistence Migration",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(workflows)/incremental-migration.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Large production codebases cannot afford extended broken builds. Coexistence strategies (pnpm aliases or keeping v2 component packages) allow teams to migrate files incrementally and maintain a working build."
    },
    {
      "id": "pnpm_aliases_strategy",
      "label": "pnpm Aliases Strategy (Strategy A)",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(workflows)/incremental-migration.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Utilizes pnpm package aliases to install both v2 and v3 versions of the main heroui package side-by-side (e.g. importing v3 components from @heroui-v3/react), enabling step-by-step migration."
    },
    {
      "id": "component_packages_strategy",
      "label": "Component Packages Strategy (Strategy B)",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(workflows)/incremental-migration.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Uses v2 component-specific packages (@heroui/button) alongside v3's unified package, keeping non-migrated components intact while transition proceeds."
    },
    {
      "id": "mcp_server_concept",
      "label": "Migration Model Context Protocol Server",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(migration-for-agents)/mcp-server.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Provides remote AI assistant tools and prompts deployed as a standard Model Context Protocol server, enabling automated and guided code generation during migration."
    },
    {
      "id": "agent_skills_concept",
      "label": "Migration Agent Skills",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(migration-for-agents)/agent-skills.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Pre-packaged files, scripts, and guides designed to be auto-discovered by developer environments, providing locally executable code migration logic."
    },
    {
      "id": "agents_md_concept",
      "label": "AGENTS.md and CLAUDE.md Indexing",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(migration-for-agents)/agents-md.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "A file-based markdown index that points AI coding assistants directly to migration workflows, hooks, styling, and component documentation downloaded locally."
    },
    {
      "id": "synchronized_shimmer_effect",
      "label": "Synchronized Shimmer Effect",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/skeleton.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Applying skeleton--shimmer on a parent container allows all child Skeletons with animationType='none' to share a single, synchronized sweep effect, improving visual loading consistency."
    },
    {
      "id": "snippet_removal_rationale",
      "label": "Snippet Component Removal",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/snippet.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Removed in v3 to avoid wrapper bloat. Easily replaced by native HTML pre/code elements, modern Clipboard API, and standard Tailwind CSS classes."
    },
    {
      "id": "spacer_removal_rationale",
      "label": "Spacer Component Removal",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/spacer.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Removed in v3 in favor of standard Tailwind spacing utilities (gap, margin, space-y), aligning with modern layouts and preventing unnecessary DOM node creation."
    },
    {
      "id": "user_removal_rationale",
      "label": "User Component Removal",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/user.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Removed in v3 to let developers compose user layouts manually with Avatar and flex elements. This maximizes design customization without locking users to a rigid preset."
    }
