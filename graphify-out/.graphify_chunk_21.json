      "id": "compound_components_concept",
      "label": "Compound Components Pattern",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/index.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "v3 shifts from config props to explicit compound component layout (e.g. Card.Header, Card.Content) to give developers direct, structural control over layouts."
    },
    {
      "id": "css_first_concept",
      "label": "CSS-First Styling Architecture",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/styling.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Replaces utility classes generated via Tailwind plugin in v2 with pre-packaged static CSS files, reducing JavaScript overhead and streamlining custom styling."
    },
    {
      "id": "overlay_state_concept",
      "label": "Overlay State Management",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/hooks.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Replaces useDisclosure with useOverlayState to provide a cleaner state management API and standard alignment with React Aria Components."
    },
    {
      "id": "color_system_concept",
      "label": "Color System Overhaul",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/styling.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Migrates to OKLCH color model, rebrands primary to accent, drops the secondary color token, and removes numbered shades in favor of semantic naming."
    },
    {
      "id": "item_identity_concept",
      "label": "Item Identity Split",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/index.mdx",
