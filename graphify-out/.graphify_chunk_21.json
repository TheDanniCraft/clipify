      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Differentiates React list keys from selection state IDs and textValue accessibility triggers in collection components."
    },
    {
      "id": "coexistence_strategies_concept",
      "label": "Migration Coexistence Strategies",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/index.mdx",
