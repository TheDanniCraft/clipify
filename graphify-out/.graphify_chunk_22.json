    {
      "id": "compound_components_pattern",
      "label": "Compound Components Pattern",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/modal.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "HeroUI v3 shifts from single monolithic components with complex props to a compound component pattern to give developers fine-grained layout control, better styling support, and clean DOM structures."
    },
    {
      "id": "native_html_tailwind_replacement",
      "label": "Native HTML & Tailwind Replacement",
      "file_type": "rationale",
      "source_file": ".heroui-docs/migration/(components)/code.mdx",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "HeroUI v3 removes simple wrapper components (like Code, Image, Navbar) and advises using native HTML elements decorated with Tailwind CSS classes, reducing bundle size and increasing flexibility."
    },
    {
