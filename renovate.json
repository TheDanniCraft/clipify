{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"rangeStrategy": "bump",
	"branchPrefix": "renovate/",
	"additionalBranchPrefix": "{{{manager}}}/",
	"labels": ["dependencies", "renovate"],
	"commitMessagePrefix": "⬆️ Bump ",
	"commitMessageAction": "",
	"commitMessageTopic": "{{depName}}",
	"commitMessageExtra": " to {{newVersion}}",
	"packageRules": [
		{
			"matchDepTypes": ["patchedDependencies"],
			"groupName": "Bun patched dependency updates"
		},
		{
			"groupName": "next/react ecosystem",
			"matchPackageNames": ["/^next$/", "/^react$/", "/^react-dom$/", "/^eslint-config-next$/", "/^next-/"]
		},
		{
			"groupName": "database (drizzle/pg)",
			"matchPackageNames": ["/^drizzle-/", "/^pg$/", "/^@types/pg$/"]
		},
		{
			"groupName": "typescript & types",
			"matchPackageNames": ["/^@types//", "/^typescript$/", "/^tsx$/"]
		},
		{
			"groupName": "linting",
			"matchPackageNames": ["/^eslint$/"]
		},
		{
			"groupName": "tailwind",
			"matchPackageNames": ["/^tailwindcss$/", "/^@tailwindcss//"]
		},
		{
			"groupName": "stripe",
			"matchPackageNames": ["/^stripe$/"]
		},
		{
			"matchManagers": ["github-actions"],
			"groupName": "github actions"
		},
		{
			"matchManagers": ["dockerfile"],
			"groupName": "docker images"
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"description": "Keep Bun patchedDependencies bound to the installed package version",
			"managerFilePatterns": ["/(^|\\/)package\\.json$/"],
			"matchStrings": ["(?<depName>(?:@[^\"@/]+/)?[^\"@]+)@(?<currentValue>[^\"]+)\"\\s*:\\s*\"(?<patchFile>patches/[^\" ]+\\.patch)\""],
			"depTypeTemplate": "patchedDependencies",
			"datasourceTemplate": "npm",
			"versioningTemplate": "npm"
		}
	]
}
