{
	"name": "clipify",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"app:dev": "RUNNER_ARTIFACT_SOURCE=local infisical run --env=dev --watch -- next dev",
		"app:webhook": "stripe listen --forward-to localhost:3000/payment/webhook",
		"app:eventsub": "ngrok http 3000 --url https://well-free-wildcat.ngrok-free.app",
		"app:build": "next build",
		"app:check-action-manifest": "node scripts/check-server-action-manifest.mjs",
		"app:start": "next start",
		"app:lint": "eslint .",
		"app:prettier": "prettier --write .",
		"git:staged": "lint-staged",
		"app:typecheck": "tsc --noEmit",
		"runner:dev": "tsx watch packages/runner/src/index.ts",
		"runner:build": "NODE_ENV=development bun packages/runner/build.mjs",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage --runInBand",
		"db:push": "infisical run --env=dev -- drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "infisical run --env=dev -- drizzle-kit studio",
		"prepare": "next-ws patch && husky",
		"stream:test": "tsx scripts/stream-test.ts"
	},
	"dependencies": {
		"@heroui/react": "^3.2.2",
		"@heroui/styles": "^3.2.2",
		"@sentry/nextjs": "^10.65.0",
		"@tabler/icons-react": "^3.44.0",
		"@types/ffbinaries": "^1.1.5",
		"axios": "^1.18.1",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"fluent-ffmpeg": "^2.1.3",
		"jsonwebtoken": "^9.0.3",
		"minimatch": "^10.2.5",
		"motion": "^12.42.2",
		"next": "^16.2.10",
		"next-navigation-guard": "^0.2.0",
		"next-plausible": "^4.0.0",
		"next-themes": "^0.4.6",
		"next-ws": "^2.2.8",
		"nextjs-turnstile": "^1.0.5",
		"pg": "^8.22.0",
		"rate-limiter-flexible": "^11.2.0",
		"re2js": "^2.8.6",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"recharts": "^3.9.2",
		"stripe": "^22.3.1",
		"tailwind-variants": "^3.2.2",
		"usesend-js": "^1.6.3",
		"ws": "^8.21.1",
		"xss": "^1.0.15"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.3.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node-media-server": "^2.3.7",
		"@types/node": "^26.1.1",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vercel/nft": "^1.10.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.5",
		"eslint-config-next": "^16.2.10",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.5",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3"
	},
	"patchedDependencies": {
		"next@16.1.6": "patches/next.patch"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md}": [
			"prettier --write"
		]
	}
}
