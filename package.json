{
	"name": "clipify",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"app:dev": "infisical run --env=dev --watch -- next dev --webpack",
		"app:webhook": "stripe listen --forward-to localhost:3000/payment/webhook",
		"app:eventsub": "ngrok http 3000 --url https://well-free-wildcat.ngrok-free.app",
		"app:build": "next build --webpack",
		"app:start": "next start",
		"app:lint": "eslint .",
		"app:typecheck": "tsc --noEmit",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage --runInBand",
		"db:push": "infisical run --env=dev -- drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "infisical run --env=dev -- drizzle-kit studio",
		"prepare": "next-ws patch && husky"
	},
	"dependencies": {
		"@heroui/react": "^2.8.10",
		"@sentry/nextjs": "^10.52.0",
		"@tabler/icons-react": "^3.41.1",
		"axios": "^1.15.2",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"jsonwebtoken": "^9.0.3",
		"minimatch": "^10.2.5",
		"motion": "^12.38.0",
		"next": "^16.2.4",
		"next-navigation-guard": "^0.2.0",
		"next-plausible": "^4.0.0",
		"next-themes": "^0.4.6",
		"next-ws": "^2.2.5",
		"nextjs-turnstile": "^1.0.5",
		"pg": "^8.20.0",
		"rate-limiter-flexible": "^11.0.1",
		"re2js": "^2.3.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"recharts": "^3.8.1",
		"stripe": "^22.1.0",
		"usesend-js": "^1.6.3",
		"ws": "^8.20.0",
		"xss": "^1.0.15"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vercel/nft": "^1.5.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.4",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"patchedDependencies": {
		"next@16.1.6": "patches/next@16.1.6.patch"
	}
}
